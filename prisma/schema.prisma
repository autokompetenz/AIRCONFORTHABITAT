generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  available
  out_of_stock
  discontinued
}

enum OrderStatus {
  pending
  confirmed
  preparing
  shipped
  delivered
  cancelled
}

enum DeliveryMethod {
  pickup
  delivery
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  icon     String?
  sort     Int       @default(0)
  isActive Boolean   @default(true)
  createdAt DateTime @default(now())

  products Product[]
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String        @unique
  type        String        // climatiseur_fixe, climatiseur_mobile, ventilateur
  brand       String
  model       String
  description String?       @db.Text
  technicalDescription String? @db.Text
  price       Float
  salePrice   Float?
  btu         String?
  surface     String?       // surface recommandée en m²
  noiseLevel  Float?        // dB
  energyClass String?       // A++, A+, A, B, C
  cop         Float?        // COP performance
  seer        Float?        // SEER
  scop        Float?        // SCOP
  color       String?
  weight      Float?
  dimensions  String?
  warranty    String?       // durée garantie
  stock       Int           @default(0)
  status      ProductStatus @default(available)
  featured    Boolean       @default(false)
  isActive    Boolean       @default(true)
  imageUrl    String?
  imageUrl2   String?
  imageUrl3   String?
  imageUrl4   String?
  imageUrl5   String?
  videoUrl    String?
  categoryId  Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category   Category?   @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  address   String?
  createdAt DateTime @default(now())

  orders Order[]
}

model Order {
  id              Int           @id @default(autoincrement())
  orderNumber     String        @unique
  customerId      Int?
  customerName    String
  customerEmail   String
  customerPhone   String
  customerAddress String?
  deliveryMethod  DeliveryMethod @default(pickup)
  deliveryAddress String?
  paymentMethod   String         @default("transfer")
  paymentStatus   String         @default("pending")
  totalAmount     Float?
  notes           String?        @db.Text
  status          OrderStatus    @default(pending)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  customer Customer?   @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  tracking OrderTracking[]
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int   @default(1)
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model OrderTracking {
  id        Int         @id @default(autoincrement())
  orderId   Int
  status    OrderStatus
  comment   String?     @db.Text
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  action    String
  detail    String?  @db.Text
  createdAt DateTime @default(now())
}

model StockAlert {
  id        Int      @id @default(autoincrement())
  productId Int?
  productName String?
  brand     String?
  name      String
  email     String
  phone     String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
}
